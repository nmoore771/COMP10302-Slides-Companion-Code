<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>The Planets</title>
    <style>
        table, td { border : 1px solid black; }
    </style>
</head>
<body>
    <h3> Safe, XSS filtering Double Moustaches </h3>
    <table>
        <thead>
            <tr>
                <th> Region </th> <th> Location </th>
            </tr>
        </thead>
        <tbody>
            {{#each regions}}
            <tr>
                <td> {{this.name}} </td>
                <td> {{this.location}} </td>
            </tr>
            {{/each}}
        </tbody>
    </table>
    <h3> Unsafe, XSS Ignoring Triple Moustaches </h3>
    <table>
        <thead>
        <tr>
            <th> Region </th> <th> Location </th>
        </tr>
        </thead>
        <tbody>
        {{#each regions}}
            <tr>
                <td> {{{this.name}}} </td>
                <td> {{{this.location}}} </td>
            </tr>
        {{/each}}
        </tbody>
    </table>
</body>
</html>